{
    "name": "condoedge/discussions",
    "description": "Channels, discussions and chat components for Kompo applications",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Kompo\\Discussions\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "laravel/framework": ">=5.6.0",
        "kompo/kompo": "*",
        "kompo/auth": "*",
        "condoedge/utils": "^0.2.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kompo\\Discussions\\KompoDiscussionsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
